---
import { Image } from 'astro:assets'
import avatar from '../assets/avatar.avif'
import Footer from '../components/Footer.astro'
import Link from '../components/Link.astro'
import SocialLink from '../components/SocialLink.astro'
import ThoughtListItem from '../components/ThoughtListItem.astro'
import Layout from '../layouts/Layout.astro'
import { socialLinks } from '../lib/social'
import { generatePersonSchema } from '../lib/structured-data'
import { getAllThoughtsSummary } from '../lib/thoughts'

const recentThoughts = (await getAllThoughtsSummary()).slice(0, 3)
const personSchema = generatePersonSchema()
---

<Layout structuredData={personSchema}>
	<main class="container mx-auto px-6 max-w-2xl py-12 dark:text-white">
		<div class="mb-10 flex items-center gap-5">
			<Image
				src={avatar}
				alt="Tomas Klingen"
				class="w-20 h-20 rounded-full object-cover"
				style={{ viewTransitionName: 'avatar' }}
				width={80}
				height={80}
			/>
			<h1 class="text-3xl font-bold">Hi, I'm Tomas</h1>
		</div>

		<p class="text-gray-600 dark:text-gray-300 mb-4">
			A Front-end Web Developer from Nieuwegein, Netherlands. My passion lies in
			crafting engaging web experiences with modern technologies. When I'm not
			at the keyboard, you can find me cycling,{' '}
			<Link href="/run/5k" variant="accent">running</Link>, or doing Crossfit.
		</p>

		<div class="flex gap-3 mb-12">
			<SocialLink
				social={socialLinks.bluesky}
				class="text-neutral-400 hover:text-neutral-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors"
				iconClass="w-5 h-5"
			/>
			<SocialLink
				social={socialLinks.linkedin}
				class="text-neutral-400 hover:text-neutral-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors"
				iconClass="w-5 h-5"
			/>
			<SocialLink
				social={socialLinks.github}
				class="text-neutral-400 hover:text-neutral-600 dark:text-neutral-500 dark:hover:text-neutral-300 transition-colors"
				iconClass="w-5 h-5"
			/>
		</div>

		{
			recentThoughts.length > 0 && (
				<div class="mb-8">
					<div class="flex items-center justify-between mb-4">
						<h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">
							Recent Thoughts
						</h2>
						<Link href="/thoughts" variant="default" class="text-sm">
							View all →
						</Link>
					</div>
					<div class="space-y-4">
						{recentThoughts.map((thought) => (
							<ThoughtListItem
								thought={thought}
								variant="compact"
								dateFormat="short"
							/>
						))}
					</div>
				</div>
			)
		}
	</main>
	<Footer />
</Layout>
